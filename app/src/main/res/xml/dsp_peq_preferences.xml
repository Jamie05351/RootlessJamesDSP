<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <me.timschneeberger.rootlessjamesdsp.preference.SwitchPreferenceGroup
        android:disableDependentsState="false"
        android:key="@string/key_peq_enable"
        android:title="@string/peq_enable"
        android:icon="@drawable/ic_tune_vertical_variant_24dp"
        app:iconSpaceReserved="false">

        <!-- Live frequency-response graph -->
        <me.timschneeberger.rootlessjamesdsp.preference.BiquadFrequencyResponsePreference
            android:key="peq_response_graph"
            app:iconSpaceReserved="false" />

        <!-- Filter 1 -->
        <PreferenceCategory android:title="@string/peq_filter_1" app:iconSpaceReserved="false">
            <ListPreference android:key="@string/key_peq_f1_type" android:title="@string/peq_filter_type"
                android:defaultValue="0" android:dialogTitle="@string/peq_filter_type"
                android:entries="@array/peq_filter_types" android:entryValues="@array/peq_filter_types_values"
                app:useSimpleSummaryProvider="true" app:iconSpaceReserved="false" />
            <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
                android:key="@string/key_peq_f1_freq" android:title="@string/peq_freq" android:defaultValue="100"
                app:minValue="20" app:maxValue="20000" app:seekBarIncrement="10" app:precision="0" app:unit=" Hz"
                app:allowDividerAbove="false" app:updatesContinuously="true" app:showSeekBarValue="true" app:iconSpaceReserved="false" />
            <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
                android:key="@string/key_peq_f1_gain" android:title="@string/peq_gain" android:defaultValue="0"
                app:minValue="-20" app:maxValue="20" app:seekBarIncrement="1" app:precision="1" app:unit=" dB"
                app:allowDividerAbove="false" app:updatesContinuously="true" app:showSeekBarValue="true" app:iconSpaceReserved="false" />
            <me.timschneeberger.rootlessjamesdsp.preference.MaterialSeekbarPreference
                android:key="@string/key_peq_f1_q" android:title="@string/peq_q" android:defaultValue="1.0"
                app:minValue="0.1" app:maxValue="10.0" app:precision="2"
                app:allowDividerAbove="false" app:updatesContinuously="true" app:showSeekBarValue="true" app:iconSpaceReserved="false" />
        </PreferenceCategory>

        <!-- Filter 2 -->
        <PreferenceCategory android:title="@string/peq_filter_2" app:iconSpaceReserved="false">
            <ListPreference android:key="@string/key_peq_f2_type" android:title="@string/peq_filter_type"
                android:defaultValue="0" android:dialogTitle="@string/peq_filter_type"
                android:entries="@array/peq_filter_types" android:entryValues="@array/peq_filter_types_values"
